# PostgreSQL (obligatorio con Prisma). En el VPS: ver docs/POSTGRES_VPS.md
DATABASE_URL="postgresql://connectia:PASSWORD@127.0.0.1:5432/connectia"

# Auth
AUTH_SECRET="cambia_esta_clave_super_secreta"
APP_BASE_URL="http://localhost:3000"
SESSION_DAYS_DEFAULT=7
SESSION_DAYS_REMEMBER=30

# Google OAuth
GOOGLE_CLIENT_ID="tu_google_client_id.apps.googleusercontent.com"
NEXT_PUBLIC_GOOGLE_CLIENT_ID="tu_google_client_id.apps.googleusercontent.com"

# Gmail SMTP (verificación de correo)
GMAIL_USER="tu_cuenta@gmail.com"
GMAIL_APP_PASSWORD="tu_app_password_de_gmail"
MAIL_FROM="CONNECTIA <tu_cuenta@gmail.com>"

# Mensajería
MESSAGE_COOLDOWN_SECONDS=20

# Supabase (opcional; se usa solo si añades auth con Supabase más adelante)
NEXT_PUBLIC_SUPABASE_URL=https://placeholder.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=placeholder
